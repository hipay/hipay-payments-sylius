{
	"info": {
		"_postman_id": "hipay-webhook-collection",
		"name": "HiPay Webhook",
		"description": "Collection pour tester le webhook HiPay du plugin Sylius.\n\n**Configuration :**\n- `base_url` : URL de base de votre app (ex: https://localhost:8000 ou https://hipay-plugin.wip)\n- `webhook_secret` : Secret passphrase du compte HiPay (celui configuré pour l'environnement utilisé). Le secret est récupéré côté serveur via la transaction_reference du payload.\n\n**Signature :** Le header `X-Allopass-Signature` doit être la valeur **SHA256(body_raw + secret)** en hexadécimal (sans préfixe). Le body est le corps brut de la requête (application/x-www-form-urlencoded). Un script Pre-request calcule la signature si vous utilisez le body brut (raw) et la variable `webhook_secret`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "webhook_secret",
			"value": "your_secret_passphrase",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Notification - Payment Captured (118)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded",
						"type": "text"
					},
					{
						"key": "X-Allopass-Signature",
						"value": "{{signature}}",
						"type": "text",
						"description": "Calculated by Pre-request Script (SHA256 of raw body + webhook_secret)"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "state=completed&test=true&mid=00001342917&attempt_id=1&authorization_code=310214474&transaction_reference=800417743755&status=118&message=Captured&authorized_amount=15.00&captured_amount=15.00&refunded_amount=0.00&decimals=2&currency=EUR&order[id]=TEST-NOTIF-001&order[amount]=15.00&order[currency]=EUR",
					"options": {
						"raw": {
							"language": "text"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/payment/hipay/notify",
					"host": ["{{base_url}}"],
					"path": ["payment", "hipay", "notify"]
				},
				"description": "Simule une notification HiPay : paiement capturé (status 118). Remplacez transaction_reference et order[id] par des valeurs existantes dans votre Sylius si vous voulez que le traitement aboutisse."
			},
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// X-Allopass-Signature = SHA256(raw_body + webhook_secret) in hex",
							"const body = pm.request.body.raw || '';",
							"const secret = pm.collectionVariables.get('webhook_secret') || '';",
							"let hash;",
							"try {",
							"    const CryptoJS = require('crypto-js');",
							"    hash = CryptoJS.SHA256(body + secret).toString(CryptoJS.enc.Hex);",
							"} catch (e) {",
							"    // Fallback if crypto-js not available: use a placeholder; set header manually",
							"    hash = 'SET_MANUAL_SHA256_HEX';",
							"}",
							"pm.request.headers.upsert({ key: 'X-Allopass-Signature', value: hash });"
						],
						"type": "text/javascript"
					}
				}
			]
		},
