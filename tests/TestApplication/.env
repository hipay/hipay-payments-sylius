# MySQL runs in Docker (compose.yml); use 127.0.0.1:3306 from host. No password (MYSQL_ALLOW_EMPTY_PASSWORD).

# Bundle loaded via path (merged with default bundles). Path relative to plugin root.
SYLIUS_TEST_APP_BUNDLES_PATH=tests/TestApplication/config/bundles.php
SYLIUS_TEST_APP_CONFIGS_TO_IMPORT="@SyliusHiPayPlugin/tests/TestApplication/config/config.yaml"
SYLIUS_TEST_APP_ROUTES_TO_IMPORT="@SyliusHiPayPlugin/tests/TestApplication/config/routes.yaml"
MAILER_SENDER_EMAIL=test@hipay.fr
