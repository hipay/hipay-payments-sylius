# Test database — separate from dev database.
# Uses DATABASE_TEST_URL instead of DATABASE_URL to avoid Symfony CLI Docker
# injection overriding the value with the dev database.
# Uses empty password (MYSQL_ALLOW_EMPTY_PASSWORD in compose.yml).
DATABASE_TEST_URL=mysql://root@127.0.0.1:3306/sylius_hipay_plugin_test

MAILER_SENDER_EMAIL=test@example.com

HIPAY_TEST_API_USERNAME=test_user_placeholder
HIPAY_TEST_API_PASSWORD=test_pass_placeholder
HIPAY_TEST_SECRET_PASSPHRASE=test_secret_placeholder
HIPAY_TEST_PUBLIC_USERNAME=test_user_placeholder
HIPAY_TEST_PUBLIC_PASSWORD=test_pass_placeholder
HIPAY_TEST_API_USERNAME_APPLE=test_user_placeholder
HIPAY_TEST_API_PASSWORD_APPLE=test_user_placeholder
HIPAY_TEST_SECRET_PASSPHRASE_APPLE=test_user_placeholder
