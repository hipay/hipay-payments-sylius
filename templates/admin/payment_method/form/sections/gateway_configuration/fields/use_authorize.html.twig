{% set form = hookable_metadata.context.form %}
{% if form.use_authorize is defined %}
    <div class="col-12 mt-3 {{ hookable_metadata.configuration.attr.class|default('') }}">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light border-bottom">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-arrow-left-right me-2 text-muted"></i>
                    {{ 'sylius_hipay_plugin.form.configuration.section.transaction'|trans }}
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-6">
                        {{ form_row(form.use_authorize, sylius_test_form_attribute('gateway-config-capture-mode')|merge({ label_attr: { class: 'checkbox-switch' } })) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
