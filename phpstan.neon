# PHPStan configuration — PHP 8.2, modern static analysis
parameters:
    level: max
    phpVersion: 80200
    reportUnmatchedIgnoredErrors: true
    paths:
        - src
        - config
        - tests/Behat

    excludePaths:
        # Symfony DI extension (if present)
        - 'src/DependencyInjection/Configuration.php'
        # Test application (not plugin code)
        - 'tests/TestApplication/app/**.php'
        - 'tests/TestApplication/src/**.php'

    ignoreErrors:
        -
            identifier: missingType.iterableValue
